<Page x:Class="FitnessClub.Pages.WorkoutsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FitnessClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WorkoutsPage">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="Добавить" Width="80" Margin="5" Click="btnAdd_Click"/>
            <Button x:Name="btnEdit" Content="Изменить" Width="80" Margin="5" Click="btnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="80" Margin="5" Click="btnDelete_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgWorkouts" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="Тренер" Binding="{Binding Trainers.LastName}" Width="100"/>
                <DataGridTextColumn Header="Дата и время" Binding="{Binding WorkoutDateTime, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="150"/>
                <DataGridTextColumn Header="Длит. (мин)" Binding="{Binding DurationMinutes}" Width="80"/>
                <DataGridTextColumn Header="Макс. участников" Binding="{Binding MaxParticipants}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="lblTotal" Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0"/>
    </Grid>
</Page>
