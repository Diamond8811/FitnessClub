<Page x:Class="FitnessClub.Pages.MembershipsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FitnessClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MembershipsPage">

    <Grid Margin="10">
        <TabControl>
            <TabItem Header="Типы абонементов">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnAddType" Content="Добавить тип" Width="120" Margin="5" Click="btnAddType_Click"/>
                        <Button x:Name="btnEditType" Content="Изменить тип" Width="120" Margin="5" Click="btnEditType_Click"/>
                        <Button x:Name="btnDeleteType" Content="Удалить тип" Width="120" Margin="5" Click="btnDeleteType_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="dgTypes" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="Срок (дни)" Binding="{Binding DurationDays}" Width="80"/>
                            <DataGridTextColumn Header="Кол-во занятий" Binding="{Binding VisitsCount}" Width="100"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="80"/>
                            <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Абонементы клиентов">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnSell" Content="Продать абонемент" Width="150" Margin="5" Click="btnSell_Click"/>
                        <Button x:Name="btnFreeze" Content="Заморозить" Width="120" Margin="5" Click="btnFreeze_Click"/>
                        <Button x:Name="btnUnfreeze" Content="Разморозить" Width="120" Margin="5" Click="btnUnfreeze_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="dgClientMemberships" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding Clients.LastName}" Width="100"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Clients.FirstName}" Width="100"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding MembershipTypes.Name}" Width="150"/>
                            <DataGridTextColumn Header="Начало" Binding="{Binding StartDate, StringFormat={}{0:dd.MM.yyyy}}" Width="90"/>
                            <DataGridTextColumn Header="Окончание" Binding="{Binding EndDate, StringFormat={}{0:dd.MM.yyyy}}" Width="90"/>
                            <DataGridTextColumn Header="Осталось" Binding="{Binding RemainingVisits}" Width="70"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
