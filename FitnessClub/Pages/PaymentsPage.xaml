<Page x:Class="FitnessClub.Pages.PaymentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FitnessClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PaymentsPage">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAdd" Content="Добавить оплату" Width="120" Margin="5" Click="btnAdd_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgPayments" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding Clients.LastName}" Width="200"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding Clients.FirstName}" Width="200"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding PaymentDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="130"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat={}{0:F2}}" Width="80"/>
                <DataGridTextColumn Header="Способ" Binding="{Binding PaymentMethod}" Width="100"/>
                <DataGridTextColumn Header="Абонемент ID" Binding="{Binding ClientMembershipId}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="lblTotal" Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0"/>
    </Grid>
</Page>
