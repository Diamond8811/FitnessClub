<Page x:Class="FitnessClub.Pages.VisitsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FitnessClub.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Посещения">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnAddVisit" Content="Отметить посещение" Width="150" Margin="5" Click="btnAddVisit_Click"/>
            <TextBox x:Name="txtSearch" Width="200" Margin="5" KeyUp="txtSearch_KeyUp"/>
            <Button Content="Поиск" Width="80" Margin="5" Click="btnSearch_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgVisits" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding Clients.LastName}" Width="100"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding Clients.FirstName}" Width="100"/>
                <DataGridTextColumn Header="Дата и время" Binding="{Binding VisitDateTime, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="150"/>
                <DataGridTextColumn Header="Занятие" Binding="{Binding Workouts.Name}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="lblTotal" Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0"/>
    </Grid>
</Page>
